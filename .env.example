# 环境变量模板
# 复制此文件为 .env.local 并填写实际值

# ========== 数据库 ==========
# 本地开发：SQLite
DATABASE_URL="file:./dev.db"

# 生产部署（Neon PostgreSQL）
# DATABASE_URL="postgresql://user:password@pg.neon.tech/neondb?sslmode=require&pgBouncer=true"

# ========== NextAuth ==========
# 生成方法：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ========== GitHub OAuth ==========
# 创建 GitHub OAuth App：Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ========== 访问控制 ==========
# 允许登录的邮箱（多个用逗号分隔）
ALLOWED_EMAILS="your-email@example.com"

# ========== Vercel Blob（生产环境必需） ==========
# 本地开发可留空（使用本地文件系统）
# 生产环境必须配置：
#   1. 在 Vercel Dashboard → Storage → Create Blob Store
#   2. 复制 Read/Write Token 到此处
#   3. 添加环境变量到 Vercel 项目设置
BLOB_READ_WRITE_TOKEN=""
